# HYG catalog on Codeberg is stored via Git LFS. HTTP "raw" URLs return an LFS pointer
# (a few lines of text), not the real CSV — use the fetch script with git + git-lfs.
#
# After the first successful fetch, pin the archive checksum:
#   sha256sum data/catalogs/hyg_v42.csv.gz
HYG_REPO_URL="https://codeberg.org/astronexus/hyg.git"
HYG_GZ_REL_PATH="data/hyg/CURRENT/hyg_v42.csv.gz"
# SHA256 of hyg_v42.csv.gz after `git lfs pull` (not of the pointer file).
HYG_GZ_SHA256="5ca9431ff364c8002a4a3efa91b2b9296746aea1543374db4cb6b4fab049d601"
