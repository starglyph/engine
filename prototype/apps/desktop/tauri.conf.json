{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Starglyph",
  "version": "0.1.0",
  "identifier": "app.starglyph.desktop",
  "build": {
    "frontendDist": "./ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Starglyph",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": ["icons/icon.png"],
    "resources": {
      "../../../data/catalogs/hyg_v42.csv.gz": "data/catalogs/",
      "../../../data/celestial/": "data/celestial/"
    }
  }
}
